{
  "name": "@dylmye/atproto-standard-site-astro-loader",
  "version": "0.0.3",
  "description": "Astro loader for Standard Site documents - add your blog posts to your Astro site!",
  "license": "ISC",
  "author": {
    "name": "Dylan Myers",
    "url": "https://github.com/dylmye"
  },
  "repository": "github:dylmye/atproto-standard-site-astro-loader",
  "homepage": "https://github.com/dylmye/atproto-standard-site-astro-loader#readme",
  "bugs": {
    "url": "https://github.com/dylmye/atproto-standard-site-astro-loader/issues"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsgo --watch",
    "build": "premove dist && tsgo && copyfiles src/index.ts dist -f",
    "check": "tsgo --noEmit && biome check",
    "check:fix": "biome check --write",
    "test": "vitest --run"
  },
  "keywords": [
    "atproto",
    "bluesky",
    "standard-site",
    "withastro",
    "astro-loader"
  ],
  "sideEffects": false,
  "dependencies": {
    "@atcute/atproto": "^3.1.11",
    "@atcute/client": "^4.2.1",
    "@atcute/lexicons": "^1.3.0",
    "@atcute/standard-site": "^1.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260419.1",
    "astro": "^6.1.8",
    "msw": "^2.13.4",
    "native-copyfiles": "^2.0.1",
    "premove": "^4.0.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "astro": ">=6.0.0"
  },
  "engines": {
    "node": ">=22.0.0 || >=24.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}